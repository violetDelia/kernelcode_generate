"""DSL return-type-from-body expectation.

创建者: 大闸蟹
最后一次更改: 大闸蟹

功能说明:
- 验证 `build_func_op` / `build_func_op_from_ast` 的函数返回类型由实际 `return` 表达式决定，而不是由函数签名或返回注解先验决定。
- 覆盖无返回注解下的 memory add、symbol compare、`float(symbol.int)`、`dma.view` 四类正向闭环。
- 覆盖“参数注解不应影响 IR 生成”这一正向边界，锁定输入/输出 IR 必须跟随 `runtime_args` 与实际返回表达式。
- 覆盖缺少显式 `return` 且没有返回注解时必须显式报错的负向边界，防止静默猜测函数输出。

使用示例:
- `PYTHONPATH=. python expectation/dsl/mlir_gen/return_type_from_body_not_signature`

关联文件:
- spec: `spec/dsl/ast.md`, `spec/dsl/mlir_gen.md`
- test: `test/dsl/test_ast.py`, `test/dsl/test_mlir_gen.py`
- 功能实现: `kernel_gen/dsl/ast.py`, `kernel_gen/dsl/mlir_gen.py`
"""
# Case 列表:
# - Case-1: 无返回注解的 `memory + memory` 显式 `return`，应生成单结果 `func.func`。
# - Case-2: 无返回注解的 `symbol gt` 显式 `return`，应返回 `i1`。
# - Case-3: 无返回注解的 `float(symbol.int)` 显式 `return`，应返回 `f32`。
# - Case-4: 无返回注解的 `dma.view` 显式 `return`，应返回 `view.result.type`。
# - Case-5: 无返回注解且没有显式 `return` 时，值表达式函数体在 `build_func_op(...)` 与 `build_func_op_from_ast(...)` 两条入口都应显式报错。
# - Case-6: `parse_function(add_memory)` 生成的 AST 进入 `build_func_op_from_ast(...)` 时，仍应按返回表达式推导结果类型。
# - Case-7: 参数注解与 runtime_args 不一致时，IR 仍必须跟随 runtime_args，不得跟随参数注解漂移。

from pathlib import Path
import sys

REPO_ROOT = Path(__file__).resolve().parents[3]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from xdsl.dialects import func
from xdsl.dialects.builtin import f32, i1

from expectation.utils.compare import assert_memory
from kernel_gen.dialect.dma import DmaViewOp
from kernel_gen.dialect.nn import NnAddOp
from kernel_gen.dialect.symbol import SymbolGtOp, SymbolToFloatOp
from kernel_gen.dsl.ast import parse_function
from kernel_gen.dsl.ast_visitor import AstVisitorError
from kernel_gen.dsl.mlir_gen import build_func_op, build_func_op_from_ast
from kernel_gen.operation.dma import view
from kernel_gen.symbol_variable.memory import Memory, MemorySpace
from kernel_gen.symbol_variable.symbol_dim import SymbolDim
from kernel_gen.symbol_variable.type import NumericType


INT_MEMORY = Memory([2, 3], NumericType.Int32, space=MemorySpace.GM)
FLOAT_MEMORY = Memory([4, 4], NumericType.Float32, space=MemorySpace.GM)
failures: list[str] = []


def expect_success(case_name: str, action) -> None:
    try:
        action()
    except Exception as exc:  # noqa: BLE001 - expectation must expose exact failure surface
        failures.append(f"{case_name}: expected success, got {type(exc).__name__}: {exc}")


def expect_ast_failure(case_name: str, action, message: str) -> None:
    try:
        action()
        failures.append(f"{case_name}: expected AstVisitorError, but build_func_op succeeded")
    except AstVisitorError as exc:
        print(f"[{case_name}] expected failure: {exc}")
        assert message in str(exc)
    except Exception as exc:  # noqa: BLE001 - expectation must expose exact failure surface
        failures.append(f"{case_name}: expected AstVisitorError, got {type(exc).__name__}: {exc}")


def add_memory(lhs: "Tensor[i32, 2, 3]", rhs: "Tensor[i32, 2, 3]"):
    out = lhs + rhs
    return out


def symbol_gt(lhs: int, rhs: int):
    return lhs > rhs


def symbol_to_float(n: int):
    return float(n)


def view_kernel(src: "Tensor[f32, 4, 4]"):
    return view(src, [1, 1], [2, 2], [1, 1])


def ambiguous(lhs: "Tensor[i32, 2, 3]", rhs: "Tensor[i32, 2, 3]"):
    lhs + rhs


def add_memory_param_hint(
    lhs: "Tensor[f16, 2, 3]",
    rhs: "Tensor[f16, 2, 3]",
):
    out = lhs + rhs
    return out


def _run_case_1() -> None:
    print("[CASE-1] 无返回注解的 `memory + memory` 显式 `return`，应生成单结果 `func.func`。")
    func_op = build_func_op(add_memory, INT_MEMORY, INT_MEMORY)
    print(func_op)
    add_ops = [op for op in func_op.body.block.ops if isinstance(op, NnAddOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(add_ops) == 1
    assert len(return_ops) == 1
    assert list(func_op.function_type.outputs) == [add_ops[0].result.type]
    assert return_ops[0].arguments[0].type == add_ops[0].result.type


def _run_case_2() -> None:
    print("[CASE-2] 无返回注解的 `symbol gt` 显式 `return`，应返回 `i1`。")
    func_op = build_func_op(symbol_gt, SymbolDim("M"), SymbolDim("N"))
    print(func_op)
    gt_ops = [op for op in func_op.body.block.ops if isinstance(op, SymbolGtOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(gt_ops) == 1
    assert len(return_ops) == 1
    assert list(func_op.function_type.outputs) == [i1]
    assert return_ops[0].arguments[0].type == i1


def _run_case_3() -> None:
    print("[CASE-3] 无返回注解的 `float(symbol.int)` 显式 `return`，应返回 `f32`。")
    func_op = build_func_op(symbol_to_float, SymbolDim("K"))
    print(func_op)
    to_float_ops = [op for op in func_op.body.block.ops if isinstance(op, SymbolToFloatOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(to_float_ops) == 1
    assert len(return_ops) == 1
    assert list(func_op.function_type.outputs) == [f32]
    assert return_ops[0].arguments[0].type == f32


def _run_case_4() -> None:
    print("[CASE-4] 无返回注解的 `dma.view` 显式 `return`，应返回 `view.result.type`。")
    func_op = build_func_op(view_kernel, FLOAT_MEMORY)
    print(func_op)
    view_ops = [op for op in func_op.body.block.ops if isinstance(op, DmaViewOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(view_ops) == 1
    assert len(return_ops) == 1
    assert list(func_op.function_type.outputs) == [view_ops[0].result.type]
    assert return_ops[0].arguments[0].type == view_ops[0].result.type


def _run_case_6() -> None:
    print("[CASE-6] `parse_function(add_memory)` 生成的 AST 进入 `build_func_op_from_ast(...)` 时，仍应按返回表达式推导结果类型。")
    func_ast = parse_function(add_memory)
    func_op = build_func_op_from_ast(func_ast, runtime_args=[INT_MEMORY, INT_MEMORY])
    print(func_op)
    add_ops = [op for op in func_op.body.block.ops if isinstance(op, NnAddOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(add_ops) == 1
    assert len(return_ops) == 1
    assert list(func_op.function_type.outputs) == [add_ops[0].result.type]
    assert return_ops[0].arguments[0].type == add_ops[0].result.type


def _run_case_7() -> None:
    print("[CASE-7] 参数注解与 runtime_args 不一致时，IR 仍必须跟随 runtime_args，不得跟随参数注解漂移。")
    func_op = build_func_op(add_memory_param_hint, INT_MEMORY, INT_MEMORY)
    print(func_op)
    add_ops = [op for op in func_op.body.block.ops if isinstance(op, NnAddOp)]
    return_ops = [op for op in func_op.body.block.ops if isinstance(op, func.ReturnOp)]
    assert len(add_ops) == 1
    assert len(tuple(func_op.args)) == 2
    assert_memory(func_op.args[0].type, INT_MEMORY)
    assert_memory(func_op.args[1].type, INT_MEMORY)
    assert_memory(add_ops[0].result.type, INT_MEMORY)
    assert list(func_op.function_type.outputs) == [add_ops[0].result.type]
    assert return_ops[0].arguments[0].type == add_ops[0].result.type


def _run_case_5_from_ast() -> None:
    print("[CASE-5B] `parse_function(ambiguous)` 进入 `build_func_op_from_ast(...)` 时，也必须显式报同一错误。")
    ambiguous_ast = parse_function(ambiguous)
    build_func_op_from_ast(ambiguous_ast, runtime_args=[INT_MEMORY, INT_MEMORY])


print("[INFO] 统一执行 return-type-from-body expectation。")
expect_success("CASE-1", _run_case_1)
expect_success("CASE-2", _run_case_2)
expect_success("CASE-3", _run_case_3)
expect_success("CASE-4", _run_case_4)
expect_ast_failure(
    "CASE-5",
    lambda: build_func_op(ambiguous, INT_MEMORY, INT_MEMORY),
    "Function return requires explicit return syntax or annotation",
)
expect_ast_failure(
    "CASE-5B",
    _run_case_5_from_ast,
    "Function return requires explicit return syntax or annotation",
)
expect_success("CASE-6", _run_case_6)
expect_success("CASE-7", _run_case_7)

if failures:
    raise AssertionError("\n".join(failures))
