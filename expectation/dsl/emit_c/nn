"""emit_c symbol expectation.

创建者: 榕
最后一次更改: 榕

功能说明:
- 使用 `build_func_op` 构造一个最小的 `symbol.add` 函数。
- 验证 DSL 中的标量 `lhs + rhs` 会生成 `symbol.add` 与 `func.return`。
- 使用 `gen_kernel` 触发代码生成，并验证当前 `emit_c` 对 `symbol.add` 的不支持错误路径。

使用示例:
- python expectation/temp_/emitc/nn

关联文件:
- spec: spec/dsl/mlir_gen.md, spec/dsl/gen_kernel.md, spec/dsl/emit_c.md, spec/dialect/symbol.md
- test: test/dsl/test_ast_visitor.py, test/dsl/test_gen_kernel.py, test/dsl/test_emit_c.py
- 功能实现: kernel_gen/dsl/mlir_gen.py, kernel_gen/dsl/gen_kernel.py, kernel_gen/dsl/emit_c.py
"""

from __future__ import annotations

from pathlib import Path
import sys

REPO_ROOT = Path(__file__).resolve().parents[3]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from expectation.utils.random import get_random_int
from kernel_gen.dialect.symbol import SymbolAddOp
from kernel_gen.dsl.emit_c import EmitCContext, EmitCError
from kernel_gen.dsl.gen_kernel import gen_kernel
from kernel_gen.dsl.mlir_gen import build_func_op
from xdsl.dialects.func import FuncOp, ReturnOp

LHS = get_random_int()
RHS = get_random_int()


def add(lhs: int, rhs: int) -> int:
    out = lhs + rhs
    return out


FUNC_OP = build_func_op(add, LHS, RHS)
OPS = list(FUNC_OP.body.block.ops)
ADD_OPS = [op for op in OPS if isinstance(op, SymbolAddOp)]
RETURN_OPS = [op for op in OPS if isinstance(op, ReturnOp)]

assert isinstance(FUNC_OP, FuncOp)
assert len(ADD_OPS) == 1
assert len(RETURN_OPS) == 1
assert RETURN_OPS[0].arguments[0] is ADD_OPS[0].result
gen_kernel(FUNC_OP, EmitCContext(target="cpu"))

