+def public_dma_helper_chain_kernel(x: Memory, y: Memory, n: int) -> None:
+    local = alloc([n, 4], NumericType.Float32, MemorySpace.SM)
+    fill(local, "inf")
+    copied = dma_copy(x, MemorySpace.SM)
+    loaded = load(x, [0, 0], [n, 4], [1, 1], MemorySpace.SM)
