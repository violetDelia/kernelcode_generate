+    wrapper_func = _func(
+        "sig_wrapper",
+        list(wrapper_input_types),
+        list(wrapper_result_types),
+        wrapper_block,
+        wrapper_arg_names,
+    )
+    return ModuleOp([body_func, wrapper_func])
